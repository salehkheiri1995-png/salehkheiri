// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Users
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  avatar    String?
  bio       String?
  phone     String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  enrollments CourseEnrollment[]
  reviews     Review[]
  bookings    Booking[]
  cart_items  CartItem[]
  orders      Order[]
}

// Courses
model Course {
  id               String   @id @default(cuid())
  title            String
  description      String   @db.Text
  instructor_name  String
  price            Float
  original_price   Float?
  duration_hours   Int
  students_count   Int      @default(0)
  rating           Float    @default(0)
  level            String   @default("مبتدی")
  course_type      String   @default("آنلاین")
  image_url        String?
  is_active        Boolean  @default(true)
  is_new           Boolean  @default(false)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  // Relations
  lessons      CourseLessonItem[]
  enrollments  CourseEnrollment[]
  reviews      Review[]
}

// Course Lessons
model CourseLessonItem {
  id               String   @id @default(cuid())
  course_id        String
  title            String
  description      String   @db.Text
  video_url        String?
  duration_minutes Int
  order_index      Int
  is_free          Boolean  @default(false)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  course Course @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@index([course_id])
}

// Course Enrollments
model CourseEnrollment {
  id           String   @id @default(cuid())
  user_id      String
  course_id    String
  email        String
  student_name String
  phone        String?
  progress     Int      @default(0)
  enrolled_at  DateTime @default(now())
  updated_at   DateTime @updatedAt

  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  course Course @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@unique([user_id, course_id])
  @@index([user_id])
  @@index([course_id])
}

// Services
model Service {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  icon_url    String?
  price       Float
  duration    Int
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  bookings Booking[]
}

// Specialists
model Specialist {
  id          String   @id @default(cuid())
  name        String
  title       String
  bio         String   @db.Text
  image_url   String?
  rating      Float    @default(5)
  phone       String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

// Products
model Product {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  price       Float
  category    String
  image_url   String?
  stock       Int      @default(0)
  rating      Float    @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  cart_items CartItem[]
  order_items OrderItem[]
  reviews    Review[]
}

// Bookings (رزرو خدمات)
model Booking {
  id           String   @id @default(cuid())
  user_id      String
  service_id   String
  date         DateTime
  time         String
  notes        String?  @db.Text
  status       String   @default("pending") // pending, confirmed, completed, cancelled
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  service Service @relation(fields: [service_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([service_id])
}

// Shopping Cart
model CartItem {
  id         String   @id @default(cuid())
  user_id    String
  product_id String
  quantity   Int      @default(1)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([user_id, product_id])
  @@index([user_id])
}

// Orders
model Order {
  id           String   @id @default(cuid())
  user_id      String
  total_price  Float
  status       String   @default("pending") // pending, paid, shipped, delivered, cancelled
  payment_method String?
  shipping_address String? @db.Text
  notes        String?  @db.Text
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  user  User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  items OrderItem[]

  @@index([user_id])
}

// Order Items
model OrderItem {
  id         String   @id @default(cuid())
  order_id   String
  product_id String
  quantity   Int
  price      Float
  created_at DateTime @default(now())

  order   Order   @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([order_id])
  @@index([product_id])
}

// Reviews
model Review {
  id         String   @id @default(cuid())
  user_id    String
  course_id  String?
  product_id String?
  rating     Int
  comment    String   @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user    User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  course  Course?  @relation(fields: [course_id], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([course_id])
  @@index([product_id])
}
